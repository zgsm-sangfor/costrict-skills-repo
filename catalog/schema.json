{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "type", "description", "source_url", "stars", "category", "tags", "tech_stack", "install", "source", "last_synced"],
    "properties": {
      "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "name": { "type": "string" },
      "type": { "type": "string", "enum": ["mcp", "skill", "rule", "prompt"] },
      "description": { "type": "string" },
      "source_url": { "type": "string", "format": "uri" },
      "stars": { "type": ["integer", "null"] },
      "pushed_at": { "type": ["string", "null"], "description": "ISO 8601 timestamp of last repo push" },
      "coding_relevance": { "type": ["integer", "null"], "minimum": 1, "maximum": 5, "description": "LLM-scored coding relevance (1-5)" },
      "quality_score": { "type": ["integer", "null"], "minimum": 1, "maximum": 5, "description": "LLM-scored quality (1-5)" },
      "category": { "type": "string", "enum": ["frontend", "backend", "fullstack", "mobile", "devops", "database", "testing", "security", "ai-ml", "tooling", "documentation"] },
      "tags": { "type": "array", "items": { "type": "string" } },
      "tech_stack": { "type": "array", "items": { "type": "string" } },
      "install": {
        "type": "object",
        "required": ["method"],
        "properties": {
          "method": { "type": "string", "enum": ["mcp_config", "mcp_config_template", "manual", "git_clone", "download_file"] },
          "config": { "type": "object" },
          "placeholder_hints": {
            "type": "object",
            "description": "Map of placeholder name to user-friendly description, e.g. {\"PATH_TO_API_DOT_JSON\": \"TypeDoc generated API JSON file path\"}",
            "additionalProperties": { "type": "string" }
          },
          "target_dir": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "repo": { "type": "string" }
        }
      },
      "health": {
        "type": "object",
        "description": "Composite health score and signals",
        "properties": {
          "score": { "type": "integer", "minimum": 0, "maximum": 100 },
          "signals": {
            "type": "object",
            "properties": {
              "popularity": { "type": "integer", "minimum": 0, "maximum": 100 },
              "freshness": { "type": "integer", "minimum": 0, "maximum": 100 },
              "quality": { "type": "integer", "minimum": 0, "maximum": 100 },
              "installability": { "type": "integer", "minimum": 0, "maximum": 100 }
            }
          },
          "freshness_label": { "type": "string", "enum": ["active", "stale", "abandoned"] },
          "last_commit": { "type": ["string", "null"] }
        }
      },
      "source": { "type": "string" },
      "last_synced": { "type": "string", "format": "date" }
    }
  }
}
